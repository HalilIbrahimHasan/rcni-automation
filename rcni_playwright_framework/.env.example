# Copy this file to .env and fill in your real values:
#   copy .env.example .env

GA_URL=
GA_EMAIL=
GA_PASSWORD=
HEADLESS=false
SLOW_MO=0
VIDEO=false
TRACE=false

# Browser: use chromium (Playwright bundled — no Google Chrome install needed)
# Only set chrome/msedge if you have those browsers installed on your PC
BROWSER=chromium
BROWSER_CHANNEL=
BROWSER_EXECUTABLE=
BROWSER_STABILITY_ARGS=true
BROWSER_FALLBACK=false
BROWSER_EXTRA_ARGS=

# Optional: GetInsured portal credentials (834 download flow)
GI_URL=
GI_EMAIL=
GI_PASSWORD=

# Optional: timeout overrides (milliseconds)
DEFAULT_TIMEOUT=20000
NAVIGATION_TIMEOUT=60000
REPORT_WAIT_TIMEOUT=15000
BROWSER_LAUNCH_TIMEOUT=30000
TEST_TIMEOUT=300
DOWNLOAD_TIMEOUT=3600000
