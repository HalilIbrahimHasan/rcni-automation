GA_URL=https://dummy-url.example.com
GA_EMAIL=dummy@example.com
GA_PASSWORD=dummy_password
HEADLESS=false
SLOW_MO=0
VIDEO=false
TRACE=false

# Browser: chromium | chrome | msedge | firefox | webkit
# Use "chrome" on Windows to open installed Google Chrome (recommended)
BROWSER=chrome
BROWSER_CHANNEL=
BROWSER_EXECUTABLE=
BROWSER_STABILITY_ARGS=true
BROWSER_FALLBACK=false
# Extra args comma-separated, e.g. --disable-gpu,--window-size=1920,1080
BROWSER_EXTRA_ARGS=

# Optional: GetInsured portal credentials (834 download flow)
GI_URL=https://dummy-getinsured.example.com
GI_EMAIL=dummy@example.com
GI_PASSWORD=dummy_password

# Optional: timeout overrides (milliseconds)
DEFAULT_TIMEOUT=20000
NAVIGATION_TIMEOUT=60000
REPORT_WAIT_TIMEOUT=15000
BROWSER_LAUNCH_TIMEOUT=30000
TEST_TIMEOUT=300
DOWNLOAD_TIMEOUT=3600000
